rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Well data collections — read-only from clients
    match /operators/{docId} {
      allow read: if true;
      allow write: if false;
    }
    match /wells/{docId} {
      allow read: if true;
      allow write: if false;
    }
    match /wells_inactive/{docId} {
      allow read: if true;
      allow write: if false;
    }
    match /disposals/{docId} {
      allow read: if true;
      allow write: if false;
    }
    match /customers/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Operator aliases — read-only from clients (admin writes via Admin SDK)
    match /operatorAliases/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Custom locations — driver-typed names saved on submit, readable for autocomplete
    match /customLocations/{docId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if false;
    }

    // Unmatched entries — clients can create, nobody can read (admin reads via Admin SDK)
    match /unmatchedLocations/{docId} {
      allow create: if true;
      allow read, update, delete: if false;
    }
    match /unmatchedCompanies/{docId} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // Company config — dashboard manages
    match /companies/{docId} {
      allow read: if true;
      allow write: if true;

      // SWD Directory — company-scoped disposal site aliases/customs
      match /swd_directory/{entryId} {
        allow read, write: if true;
      }

      // Counters — invoice/ticket number auto-increment from Dashboard Add Pull
      match /counters/{counterId} {
        allow read, write: if true;
      }

      // Equipment specs — tare weight, capacity, make/model
      match /equipment_specs/{specId} {
        allow read, write: if true;
      }
    }

    // Invoices — clients can read, create, update, delete (cancel/recycle flow)
    match /invoices/{docId} {
      allow read, write: if true;
    }

    // Invoice blocks — read-only (assigned via Cloud Functions with Admin SDK)
    match /invoiceBlocks/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Tickets — clients can read and write (submit, edit, void/cancel flow)
    match /tickets/{docId} {
      allow read, write: if true;
    }

    // Ticket blocks — read-only (assigned via Cloud Functions with Admin SDK)
    match /ticketBlocks/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Route recordings — GPS breadcrumb trips recorded by drivers
    match /route_recordings/{slug} {
      allow read, write: if true;
      match /trips/{tripId} {
        allow read, write: if true;
      }
    }

    // Route overrides — golden routes selected by admin
    match /route_overrides/{slug} {
      allow read, write: if true;
    }

    // Location corrections from drivers
    match /locationCorrections/{correctionId} {
      allow read, write: if true;
    }

    // Dispatches — dashboard creates, WB T app reads/updates
    match /dispatches/{jobId} {
      allow read, write: if true;
    }

    // Load transfers — driver-to-driver handoff
    match /transfers/{transferId} {
      allow read, write: if true;
    }

    // Payroll deductions — dashboard manages
    match /deductions/{deductionId} {
      allow read, write: if true;
    }

    // Payroll additions (bonuses/reimbursements) — dashboard manages
    match /additions/{additionId} {
      allow read, write: if true;
    }

    // Billing records — dashboard manages
    match /billing_invoices/{billingId} {
      allow read, write: if true;
    }

    // Billing number counters — dashboard auto-increment
    match /billing_counters/{companyId} {
      allow read, write: if true;
    }

    // Diesel price history — dashboard manages
    match /diesel_prices/{priceId} {
      allow read, write: if true;
    }

    // Billing export invoice counters — dashboard auto-increment
    match /billing_invoice_counters/{companyId} {
      allow read, write: if true;
    }

    // Billing export audit trail — dashboard manages
    match /billing_exports/{exportId} {
      allow read, write: if true;
    }

    // Driver shift tracking — DOT compliance
    match /driver_shifts/{shiftId} {
      allow read, write: if true;
    }

    // Vehicle documents — admin uploads, drivers read
    match /vehicle_documents/{docId} {
      allow read, write: if true;
    }

    // Job packages — config-driven job types (water hauling, aggregate, etc.)
    match /job_packages/{packageId} {
      allow read: if true;
      allow write: if false;
    }

    // App registry — WB ecosystem app switcher (read-only, WB admin writes via Admin SDK)
    match /app_registry/{appId} {
      allow read: if true;
      allow write: if false;
    }

    // Overweight fine schedules — per-state (read-only, WB admin writes via Admin SDK)
    match /overweight_fines/{stateId} {
      allow read: if true;
      allow write: if false;
    }

    // Job type usage tracking — R&D pipeline for custom job type promotion/pruning
    match /job_type_usage/{typeId} {
      allow read, write: if true;
    }

    // Projects — long-running multi-day job containers
    match /projects/{projectId} {
      allow read, write: if true;
    }

    // Chat threads — real-time messaging between drivers and dispatch
    match /chat_threads/{threadId} {
      allow read, write: if true;
      match /messages/{messageId} {
        allow read, create: if true;
        allow update, delete: if false; // Messages are immutable
      }
    }

    // Chat monitor profiles — dispatch grid configurations
    match /chat_monitors/{monitorId} {
      allow read, write: if true;
    }

    // JSA records — Job Safety Analysis forms
    match /jsas/{jsaId} {
      allow read, write: if true;
    }

    // JSA day status — universal location stamps + completion tracking
    match /jsa_day_status/{docId} {
      allow read, write: if true;
    }

    // JSA completions — legacy collection
    match /jsa_completions/{docId} {
      allow read, write: if true;
    }

    // Daps waitlist — landing page signups
    match /daps_waitlist/{docId} {
      allow read: if false;
      allow create: if true;
    }

    // JSA templates — company-specific JSA configurations (BYOJSA)
    match /jsa_templates/{companyId} {
      allow read, write: if true;
      match /templates/{templateId} {
        allow read, write: if true;
      }
    }

    // WB diagnostics — read-only for the dashboard admin viewer
    // (capability-gated client-side; the read here is auth-gated to
    // any signed-in dashboard user, which already excludes anonymous
    // and app callers). Writes flow only through the Cloud Function
    // `writeDiagnosticLog`, which uses Admin SDK and bypasses rules.
    match /wb_diagnostics/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Everything else — deny (Cloud Functions use Admin SDK which bypasses rules)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
